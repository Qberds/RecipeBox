{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=recipebox.db"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/recipebox",
    "ClientId": "recipebox-web",
    "ClientSecret": "your-client-secret-here"
  }
}
